//******************************************************************************
// Gestione uscita da Windows NT 4
void __stdcall SystemShutDown(s32 mode)
//******************************************************************************
{
  HANDLE hToken;
  TOKEN_PRIVILEGES tkp;
  AnsiString error;
  TOKEN_PRIVILEGES TTPold;
  DWORD len;
  // Get a token for this process.
  if (!OpenProcessToken(GetCurrentProcess(),
                        TOKEN_ADJUST_PRIVILEGES |TOKEN_QUERY,
                        &hToken))
  {
    error ="OpenProcessToken";
  }
  // Get the LUID for the shutdown privilege.
  LookupPrivilegeValue(NULL,
                       "SeShutdownPrivilege",
                       &(tkp.Privileges[0].Luid));
  tkp.PrivilegeCount =1; // one privilege to set
  tkp.Privileges[0].Attributes =SE_PRIVILEGE_ENABLED;
  // Get the shutdown privilege for this process.
  AdjustTokenPrivileges(hToken,
                        false,
                        &tkp,
                        sizeof(TOKEN_PRIVILEGES),
                        &TTPold,
                        &len);
  // Cannot test the return value of AdjustTokenPrivileges.
  if (GetLastError() !=ERROR_SUCCESS)
  {
    error ="AdjustTokenPrivileges";
  }
  // 1 = Forcefully close apps, shutdown and leave system at shutoff point
  if (mode ==1)
  {
    if(!ExitWindowsEx(EWX_SHUTDOWN |EWX_FORCE, 0))
    {
      error ="ExitWindowsEx";
    }
  }
  // 2 = Forcefully close apps, shutdown and reboot
  if(mode ==2)
  {
    if (!ExitWindowsEx(EWX_REBOOT |EWX_FORCE, 0))
    {
      error ="ExitWindowsEx";
    }
  }
  // 3 = Forcefully close apps, and logoff
  if(mode ==3)
  {
    if(!ExitWindowsEx(EWX_LOGOFF |EWX_FORCE, 0))
    {
      error ="ExitWindowsEx";
    }
  }                         
}
