void __fastcall TFormMain::ServerConnect(TIdPeerThread *AThread)
{
	AnsiString Address =AThread->Connection->Binding->PeerIP;
	s32 Periferica =Ethernet->IdTesta(Address);
	// Verifica se la connessione e' di una periferica
	if(Periferica >0 && Periferica <=254)
	{
		// Create a client object
		C_SIMPLECLIENT *Client =new C_SIMPLECLIENT;
		Client->ListLink =0;
		// Assign the thread to it
		Client->Thread =AThread;
		// Create Command semaphore in Manual reset , Signalled
		Client->Sem_cmd =CreateEvent(NULL, true, true, NULL);
		// Create Acknoweledge semaphore in Manual reset , not Signalled
		Client->Sem_ack =CreateEvent(NULL, true, false, NULL);
    // Save Ip address associated to the thread
		Client->IpAddress =Address;
    // Resetta il codice dell'ultimo comando inviato alla Periferica
		Client->PreviousCmd =-1;
    // Azzera contatore di Time-out sulla risposta di comando eseguito
		Client->To =0;
    // Assegna al thread l'oggetto appena compilato
		AThread->Data =Client;
		// Lo aggiunge alla Client list
		ClientList->Add(Client);
	}
}
//------------------------------------------------------------------------------
void __fastcall TFormMain::ServerExecute(TIdPeerThread *AThread)
{
	if(Ethernet->OffLine)
	{
		return;
	}
	AnsiString Address =AThread->Connection->Binding->PeerIP;
	// Calcola l'identificatore della testa che ha risposto in base all'indirizzo
	s32 IdTh =Ethernet->IdThread(Address);
	if(IdTh <0)
	{
		return;
	}
	// Legge il codice del comando eseguito dalla testa
  u32 cmd =AThread->Connection->ReadCardinal(true);
	// spengo semaforo comando eseguito
	Ethernet->ClientSemaphore(IdTh, UNLOCK_SEM, SEM_CMD);
}
