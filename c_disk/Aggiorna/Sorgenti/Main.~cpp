void __fastcall TFormMain::Msg_PCName(TMessage *Message)
{
    AnsiString RegPath;
    int index;

    //Imposta il nome del computer come da commessa
    NomeComputer =PanelNomeComputer->Caption;
    //SetComputerName(NomeComputer.c_str());
    TIniFile *IFile =new TIniFile("C:\\ComputerName.ini");
