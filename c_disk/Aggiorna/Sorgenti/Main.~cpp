//******************************************************************************
int __fastcall TFormMain::InitializeProgramData()
//******************************************************************************
{
  TIniFile *IFile =new TIniFile(ChangeFileExt(Application->ExeName, ".INI"));
  if(IFile ==NULL)
  {
    return(error =1);
  }
  AnsiString Dummy;
  // Default Assignement
  DriveSet->Add("D:\\");
  // Logical Drives ID
  int d =1;
  do
  {
    Dummy =IFile->ReadString("Drives", "Drive" +IntToStr(d), "0");
    if(Dummy !="0")
    {
      DriveSet->Add(Dummy);
      ++ d;
    }
    else
      break;
  }while(d <MAX_DRIVE_UNIT);
  *Appl_Prefix =IFile->ReadString("Application", "Prefix ", "GKS");
  NumeroProgrammi =IFile->ReadInteger("Impostazioni", "NumeroProgrammi", 2);
  if(NumeroProgrammi >0)
  {
    //Impostazione dei percorsi da utilizzare per il caricamento dei programmi
    Programmi =new S_PROGRAM[NumeroProgrammi];
    UnZipProgram =new AnsiString[NumeroProgrammi];
    for(s32 i =0; i <NumeroProgrammi; i ++)
    {
      AnsiString str_dati ="DatiProgramma" +IntToStr(i +1);
      AnsiString str_path ="PathProgramma" +IntToStr(i +1);
      Programmi[i].PathProgramma =IFile->ReadString(str_dati ,str_path, "");
      AnsiString str_prog ="Programma" +IntToStr(i +1);
      Programmi[i].NomeProgramma =IFile->ReadString(str_dati ,str_prog, "");
      error =(Programmi[i].NomeProgramma.Length() ==0) ? error +64 : error;
      AnsiString str_rev ="CodiceRevisionePrg" +IntToStr(i +1);
      Programmi[i].CodiceProgramma =IFile->ReadString(str_dati, str_rev, "");
      error =(Programmi[i].CodiceProgramma.Length() ==0) ? error +128 : error;
      AnsiString str_esisto ="NomeFileEsito" +IntToStr(i +1);
      Programmi[i].FileEsisto =IFile->ReadString(str_dati, str_esisto, "");
    }
  }
  PathVersioni =IFile->ReadString("Impostazioni", "PathVersioni", "");
  error =(PathVersioni.Length() ==0) ? error +2 : error;
  PathEseguibile =IFile->ReadString("Impostazioni", "PathEseguibile", "");
  error =(PathEseguibile.Length() ==0) ? error +4 : error;
  PathBackUp =IFile->ReadString("Impostazioni", "PathBackUp", "");
  error =(PathBackUp.Length() ==0) ? error +8 : error;
  PathDati =IFile->ReadString("Impostazioni", "PathDati", "");
  error =(PathDati.Length() ==0) ? error +16 : error;
//  PathUnZip =IFile->ReadString("Impostazioni", "PathUnZip", "");
//  error =(PathUnZip.Length() ==0) ? error +32 : error;
  // This path is optional
  PathDll =IFile->ReadString("Impostazioni", "PathDll", "");
  PathBmp =IFile->ReadString("Impostazioni", "PathBmp", "");
  IdComputer =IFile->ReadString("Impostazioni", "IdComputer", "");
  // Files
  AutoSpegnimento =IFile->ReadBool("Sistema", "AutoSpegnimento", false);
  FileErrato =IFile->ReadString("Messaggi", "FileErrato","");
  ErroreCartellaApplicazione =IFile->ReadString("Messaggi", "ErroreCartellaApplicazione","");
  ErroreApplicazione =IFile->ReadString("Messaggi", "ErroreApplicazione","");
  ErroreProcesso =IFile->ReadString("Messaggi", "ErroreProcesso","");
  AggiornamentoTerminato =IFile->ReadString("Messaggi", "AggiornamentoTerminato","");

  delete IFile;

  return(error);
}

//******************************************************************************
void __fastcall TFormMain::CreaFileVersione(int prog)
//******************************************************************************
{
  // Cancella eventuali files di versione precedenti
  if(!DirectoryExists(Programmi[prog].PathProgramma +PathVersioni))
  {
    ForceDirectories(Programmi[prog].PathProgramma +PathVersioni);
  }
  AnsiString Dum =Programmi[prog].PathProgramma +"*.*";
  TSearchRec SearchRec;
  int esito =FindFirst(Dum, faAnyFile, SearchRec);
  while(esito ==0)
  {
    Dum =PathVersioni +SearchRec.Name;
    if(Dum.Pos(Programmi[prog].CodiceProgramma))
    {
      DeleteFile(Dum);
    }
    esito =FindNext(SearchRec);
  }
  FindClose(SearchRec);
  // crea il file di versione SW partendo dal file sul disco di aggiornamento.
  if(UnZipProgram[prog].Length())
  {
    Dum =Programmi[prog].PathProgramma +
         PathVersioni +
         ChangeFileExt(UnZipProgram[prog], ".VER");
    FILE *stream =fopen(Dum.c_str(), "w+");
    fprintf(stream, "%s", DateTimeToStr(Now()).c_str());
    fclose(stream);
  }  
}
//******************************************************************************
void __fastcall TFormMain::RipristinaFileDati(int prog)
//******************************************************************************
{
  TSearchRec Sr;
  AnsiString Src;
  AnsiString Dst;
  AnsiString path_backup =Programmi[prog].PathProgramma +PathBackUp;
  AnsiString path_dati =Programmi[prog].PathProgramma +PathDati;


  int esito =FindFirst(path_backup +"*.Txt", faAnyFile, Sr);
  while(esito ==0)
  {
    if(Sr.Name.Length() >=(s32)StrLen("Unitax_x.txt") &&
       Sr.Name.Length() <=(s32)StrLen("Unitaxx_x.txt"))
    {
      Sr.Name =ChangeFileExt(Sr.Name, "");
      s32 pos =Sr.Name.Pos("Unita");
      if(pos >0)
      {
        Sr.Name =Sr.Name.SubString(pos +StrLen("Unita"),
                                  Sr.Name.Length() -(pos +StrLen("Unita") -1));
        pos =Sr.Name.Pos("_");
        if(pos >0)
        {
          AnsiString dum =Sr.Name.SubString(1, pos -1);
          s32 u =dum.ToIntDef(0);
          dum =Sr.Name.SubString(pos +1, 1);
          s32 su =dum.ToIntDef(0);
          if(u >0 &&u <=MAX_NUM_UNITA &&su >0 &&su <=MAX_NUM_SUBUNITA)
          {
            s32 par =0;
            AnsiString Name;
            TList *Lista;
            Lista =new TList;
            while(FGenModParam->GetDataName(u, su, &path_backup,par ++, &Name))
            {
              Lista->Clear();
              if(FGenModParam->GetBakData(u, su, &path_backup, &Name, Lista))
              {
                S_valoridb *Param =(S_valoridb *)Lista->Items[0];
                FGenModParam->SaveBakData(u, su, &path_dati, &Name, &Param->Val);
              }
            }
          }
        }
      }        
    }
    esito =FindNext(Sr);
  }
  FindClose(Sr);
  // Cancella tutti i file di appoggio
  esito =FindFirst(path_dati +"*.tim", faAnyFile, Sr);
  while(esito ==0)
  {
    Dst =path_dati +Sr.Name;
    if(FileExists(Dst))
    {
      DeleteFile(Dst);
    }
    esito =FindNext(Sr);
  }
  FindClose(Sr);
}

//******************************************************************************
void __fastcall TFormMain::BackupFileDati(int prog)
//******************************************************************************
{
  if(!DirectoryExists(Programmi[prog].PathProgramma +PathBackUp))
  {
    ForceDirectories(Programmi[prog].PathProgramma +PathBackUp);
  }
  TSearchRec SearchRec;
  AnsiString Src;
  AnsiString Dst;
  // Cancella tutti i file del direttorio di back up 
  s32 esito =FindFirst(Programmi[prog].PathProgramma +
                                       PathBackUp +"*.*", faAnyFile, SearchRec);
  while(esito ==0)
  {
    if(SearchRec.Name !="." && SearchRec.Name !="..")
    {
      Dst =PathBackUp +SearchRec.Name;
      if(FileExists(Dst))
      {
        DeleteFile(Dst);
      }  
    }
    esito =FindNext(SearchRec);
  }
  FindClose(SearchRec);
  // Copia tutti i file dati dal direttorio dati a quello di backup
  esito =FindFirst(Programmi[prog].PathProgramma +
                   PathDati +
                   "*.Txt",
                   faAnyFile,
                   SearchRec);
  while(esito ==0)
  {
    Src =Programmi[prog].PathProgramma +PathDati +SearchRec.Name;
    Dst =Programmi[prog].PathProgramma +PathBackUp +SearchRec.Name;
    if(FileExists(Src))
    {
      CopyFile(Src.c_str(), Dst.c_str(), false);
    }  
    esito =FindNext(SearchRec);
  }
  FindClose(SearchRec);
  // Cancella tutti i file di appoggio
  esito =FindFirst(Programmi[prog].PathProgramma +
                   PathDati +
                   "*.tim",
                   faAnyFile,
                   SearchRec);
  while(esito ==0)
  {
    Dst =Programmi[prog].PathProgramma +PathDati +SearchRec.Name;
    if(FileExists(Dst))
    {
      DeleteFile(Dst);
    }
    esito =FindNext(SearchRec);
  }
  FindClose(SearchRec);
}

//******************************************************************************
bool __fastcall TFormMain::FindUpGradeFile()
//******************************************************************************
{
  TSearchRec sr;
  bool found =false;
  AnsiString Path;
  Path =DriveID +"*.*";
  if(FindFirst(Path, faAnyFile, sr) ==0)
  {
    do
    {
      for(int i =0; i <NumeroProgrammi; i ++)
      {
        AnsiString dum =UpperCase(sr.Name);
        int pos =dum.Pos(Programmi[i].CodiceProgramma);
        if(pos)
        {
          UnZipProgram[i] =dum;
          found =true;
        }
      }
    }while(FindNext(sr) ==0);
    FindClose(sr);
  }
  return(found);
}

//******************************************************************************
bool __fastcall TFormMain::DiskPresent()
//******************************************************************************
{//Verifica presenza del disco nel supporto indicato
  int i =0;
  bool Result =false;
  // Logical drive D has id=0 by default
  while(!Result &&i <DriveSet->Count)
  {
    DriveID =DriveSet->Strings[i ++];
    Result =FindUpGradeFile();
  }
  return(Result);
}
// ****************************************************************************
u32 __fastcall TFormMain::CrcRoll(u32 Crc)
// ****************************************************************************
{
  s32 n =1;
  while(n ++ <=8)
  {
    if((Crc & 1) ==1)
    {
      Crc >>= 1;
      Crc ^=0xA0000001;
    }
    else
    {
      Crc >>= 1;
    }
  }
  return(Crc);
}
