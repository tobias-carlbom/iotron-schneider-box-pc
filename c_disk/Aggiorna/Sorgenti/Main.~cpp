void __fastcall TFormMain::SetMAC()
{
  //Rename Tap-Win32 to grafikontrol
  TRegistry *RegKey =new TRegistry;
  RegKey->RootKey =HKEY_LOCAL_MACHINE;
  for(int indPosMAC =0;indPosMAC <=MAXGENLAN; indPosMAC ++)
  {
    AnsiString EnuNic;
    if (indPosMAC <10)
    {
      EnuNic ="\\SYSTEM\\CurrentControlSet\\Control\\Class\\{4D36E972-E325-11CE-BFC1-08002BE10318}\\000" +IntToStr(indPosMAC) +"\\";
    }
    else
    {
      EnuNic ="\\SYSTEM\\CurrentControlSet\\Control\\Class\\{4D36E972-E325-11CE-BFC1-08002BE10318}\\00" +IntToStr(indPosMAC) +"\\";
    }
    RegKey->OpenKey(EnuNic, false);
    AnsiString Description =RegKey->ReadString("DriverDesc");
    if(Description.AnsiPos("TAP-Win32"))
    {
      AnsiString MacString =MacAddress();
      RegKey->WriteString("MAC", MacString);
      break;
    }
  }
}
