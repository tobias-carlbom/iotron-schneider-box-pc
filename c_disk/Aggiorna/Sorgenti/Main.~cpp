void __fastcall TFormMain::ShutDownTesta()
// ****************************************************************************
{
  if(Ethernet)
  {
    for(s32 i =0; i <Ethernet->NumPerifericheConnesse; i ++)
    {
      // Carica il puntatore al socket thread della testa a cui spedire il comando
      C_SIMPLECLIENT *Client =(C_SIMPLECLIENT *)ClientList->Items[i];
      s32 cmd[10];
      cmd[0] =SHUT_DOWN;
      cmd[1] =0;
			// add Checksum
			s32 i =0;
			u32 Crc =0xffffffff;
			while(i <2)
			{
				Crc =((Crc ^((u32)cmd[i ++] &0xff))& 0xff)|(Crc &0xff000000);
				Crc =CrcRoll(Crc);
			}
			Crc >>=1;
			cmd[i] =Crc;
      // Invia il messaggio
      if(Client->Thread->Connection->Connected())
      {
        Client->Thread->Connection->WriteBuffer(cmd, 12, true);
      }
    }
  }
}

