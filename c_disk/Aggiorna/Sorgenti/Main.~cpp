bool TFormMain::isStaticIpAvailable(AnsiString ip, s32 prog_id)
{
  AnsiString dirprog =Programmi[prog_id].PathProgramma +PathEseguibile;
  SetCurrentDir(dirprog);
  pingclient =new TIdIcmpClient(NULL);
  ping_answer =-1;
  if(pingclient)
  {
    pingclient->OnReply =IdIcmpClientReply;
    pingclient->ReceiveTimeout =1000;
    pingclient->Host =ip;
    try
    {
      pingclient->Ping();
    }
    catch (Exception &EIdSocksError)
    {
      ping_answer =-1;
    }
    SleepEx(10, false);
    delete pingclient;
  }
  return (ping_answer >0);
}

//******************************************************************************
bool TFormMain::ReadStaticIpAddressUsed(s32 prog_id, s32 addr, AnsiString* ip, AnsiString* descr)
//******************************************************************************
{
  TIniFile *IFile =new TIniFile(Programmi[prog_id].PathProgramma +PathEseguibile +"StaticIpAddressUsed.INI");
  if(IFile)
  {
    AnsiString section ="IpAddress";
    AnsiString field ="Address" +IntToStr(addr);
    *ip =IFile->ReadString(section, field, "0");
    field ="Descrizione" +IntToStr(addr);
    *descr =IFile->ReadString(section, field, "0");
    delete IFile;
    return (*ip !="0");
  }
  else
  {
    return false;
  }  
}





