      Application->ProcessMessages();
      RegPath = "regedit /S ";
      RegPath = RegPath + REGEWF_2;
      WinExecAndWait32(RegPath, SW_HIDE);
    }
    for (index=0; index <=5; index++)
    {
      WinExecAndWait32(EWFCONFIG, SW_HIDE);
      ::Sleep(500);
      Application->ProcessMessages();
    }
    Label1->Caption ="Switching OFF";
    for (index=0; index <=24; index++)
    {
     ::Sleep(500);
      Application->ProcessMessages();
    }
