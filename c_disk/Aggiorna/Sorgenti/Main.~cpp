bool __fastcall TFormMain::isComputerNameAssigned()
{
  bool computer_name_ready =false;
  AnsiString str_pc_name ="";
  if(FileExists("C:\\ComputerName.ini"))
  {
    TIniFile *IFile =new TIniFile("C:\\ComputerName.ini");
    if(IFile)
    {
      str_pc_name =IFile->ReadString("Impostazioni", "ComputerName", "");
      this->Caption =str_pc_name;
      computer_name_ready =(str_pc_name.Length() >0);
      delete IFile;
    }
  }
  if(computer_name_ready)
  {
    char dum[1000];
    unsigned long ndum;
    if(GetComputerName(&dum[0], &ndum))
    {
      computer_name_ready =(strcmp(dum, str_pc_name.c_str()) ==0);
    }
  }
  return computer_name_ready;
}
