AnsiString __fastcall TFormMain::MacAddress()
{
  AnsiString result ="";
  //Codifica Macchina
  unsigned cc =EditNumeroCommessa->Text.ToIntDef(0);
  unsigned anno1 =EditAnnoCommessa->Text.ToIntDef(0) /10;
  unsigned anno2 =EditAnnoCommessa->Text.ToIntDef(0) -anno1 *10;

  unsigned lettera =(unsigned long)(*EditAnnoCommessa->Text.c_str());
  unsigned MacAddr =(GKS30_COD <<27)+
                    (cc <<17) +
                    (anno1 <<13) +
                    (anno2 <<9);
                    (lettera <<1);
  //Trasforma in notazione Hex con spaziatura :
  AnsiString Mac =IntToHex((__int64)MacAddr, 8);
  result ="00:FF:" +Mac.SubString(0, 2) +":" +Mac.SubString(2, 2) +":" +
          Mac.SubString(4, 2) +":" +Mac.SubString(6, 2);
  return result;
}
