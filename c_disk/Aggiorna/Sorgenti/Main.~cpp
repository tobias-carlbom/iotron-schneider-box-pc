void __fastcall TFormMain::Msg_Start(TMessage *Message)
{
  //inizializzazione delle variabili del programma Aggiorna
  int r =InitializeProgramData();
  if(r)
  { // ******* Errore nel file di inizializzazione applicazione ***************
    if (r ==1)
    {
      Memo1->Lines->Add(ChangeFileExt(Application->ExeName, ".INI") +" not found!");
    }
    else
    {
      if(r & 2)
       Memo1->Lines->Add("PathVersioni in section [Impostazioni] not found!");
      if(r & 4)
       Memo1->Lines->Add("PathEseguibile in section [Impostazioni] not found!");
      if(r & 8)
       Memo1->Lines->Add("PathBackUp in section [Impostazioni] not found!");
      if(r & 16)
       Memo1->Lines->Add("PathDati in section [Impostazioni] not found!");
      if(r & 32)
       Memo1->Lines->Add("PathUnZip in section [Impostazioni] not found!");
      if(r & 64)
       Memo1->Lines->Add("Programma in section [Impostazioni] not found!");
      if(r & 128)
       Memo1->Lines->Add("RevisionCode in section [Impostazioni] not found!");
    }
    Memo1->Lines->Add(FileErrato);
    delete Appl_Prefix;
    return;
  }
  //Verifica se si tratta della prima installazione del computer
  if(!isComputerNameAssigned())
  {
    //Adeguamento nome tipo apparecchiatura
    Label11->Caption =*Appl_Prefix;
    Label12->Caption =*Appl_Prefix +"yy-";
    Label2->Caption =*Appl_Prefix + "yy-xxx-";
    Label7->Caption =*Appl_Prefix + "yy-xxx-NN";
    PanelNomeComputer->Caption = *Appl_Prefix + "YY-XXX-NN#";

    PanelComputerName->Left =(Screen->Width -PanelComputerName->Width) /2;
    PanelComputerName->Top =(Screen->Height -PanelComputerName->Height) /2;
    PanelComputerName->Visible =true;
    TimerComputerName->Enabled =true;
    //if (DirectoryExists(SECONDARY_HDD))
    //  ChkBoxFormat->Visible =true;
    delete Appl_Prefix;
    return;
  }
  for(int i =0; i <NumeroProgrammi; i ++)
  {
    AnsiString dum =Programmi[i].PathProgramma +"handle.txt";
    DeleteFile(dum);
  }
  Memo1->Lines->Add(ChangeFileExt(Application->ExeName, ".INI") +" OK");
  // Delete memo
  FormMain->Memo1->Clear();
  FormMain->Memo1->Visible =false;
  // Verify if disk with upgrade program present
  if(DiskPresent())
  {// Se č presente un disco con i programma viene richiesto l'aggiornamento
   //Ask for downloading the new upgrade
    SendMessage(Handle, WM_DISK_OK, 0, 0);
  }
  else
  {//Se non č presente nessun disco di programma vengono eseguiti i programma
   //esistenti
   //Start application
    SendMessage(Handle, WM_START_APPLICATION, 0, 0);
  }
  delete Appl_Prefix;
}

//---------------------------------------------------------------------------
void __fastcall TFormMain::Msg_StartApplication(TMessage *Message)
{//Messaggio di start application che permette di eseguire il programma stabilito
  // Verifica la necessita' di installare nuove DLL
  int res =-1;
  WinExecnotwait32(SHARE_RAMDSK_B, SW_HIDE);
  ::Sleep(6);
  for(int i =0; i<NumeroProgrammi; i++)
  {
    AnsiString dirprog =Programmi[i].PathProgramma +PathEseguibile;
    AnsiString nomeprog =Programmi[i].NomeProgramma +".Exe";
    if(DirectoryExists(dirprog) &&FileExists(dirprog +nomeprog))
    {
      SetCurrentDir(dirprog);
      if(FileExists("StaticIpAddressUsed.ini"))
      {
        Memo1->Left =FormMain->ClientRect.Left +10;
        Memo1->Top =FormMain->ClientRect.Top +10;
        Memo1->Width =300;
        Memo1->Height =FormMain->ClientRect.Height() -20;
        Memo1->Clear();
        Memo1->Visible =true;
        for(s32 addr =0; addr <10; addr ++)
        {
          AnsiString ip;
          AnsiString Descrizione;
          if(ReadStaticIpAddressUsed(i, addr, &ip, &Descrizione))
          {
            Memo1->Lines->Add("Host Description: " +Descrizione);
            Memo1->Lines->Add("Pinging address: " +ip);
            while(!isStaticIpAvailable(ip, i))
            {
              ::Sleep(100);
              Application->ProcessMessages();
            }
            Memo1->Lines->Add("Ping OK");
          }
        }
      }
      Memo1->Lines->Add("Waiting Sharing!!!");
      while (!DirectoryExists(EXIST_SHARE_B))
      {
        ::Sleep(100);
        Application->ProcessMessages();
      }
      ::Sleep(1500);
      Memo1->Clear();
      Memo1->Visible =false;
      res =WinExecNoWait(nomeprog, dirprog);
      Application->ProcessMessages();
      SleepEx(3000, false);
      Application->ProcessMessages();
    }
  }
  if(res !=0)
  {
    if(res ==-1)
    {
      SendMessage(Handle, WM_WAIT_DISK, 1, 0);
    }
    else if(res ==-2)
    {
      SendMessage(Handle, WM_WAIT_DISK, 2, 0);
    }
    else if(res ==-3)
    {
      SendMessage(Handle, WM_WAIT_DISK, 3, 0);
    }
    else
    {
      SendMessage(Handle, WM_WAIT_DISK, 0, 0);
    }
  }
  else if(res ==0)
  {
    // Application started: Job finished;
    Close();
  }
}

