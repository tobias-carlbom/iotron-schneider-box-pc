void __fastcall TFormMain::Msg_UpgradeApplication(TMessage *Message)
{
  for(int i =0; i <NumeroProgrammi; i ++)
  {
    if(UnZipProgram[i].Length())
    {
      // Fa una copia dei file dati esistenti
      BackupFileDati(i);
      // Crea la directory di appoggio del file autounzippante di aggiornamento
      if(!DirectoryExists(Programmi[i].PathProgramma))
      {
        ForceDirectories(Programmi[i].PathProgramma);
      }
      // Esegue l'aggiornamento
      WinExecAndWaitMinimized(UnZipProgram[i], DriveID);
      // Ricarica le lingue
      // InitializeProgramData();
      // Ripristina i file dei dati
      RipristinaFileDati(i);
      // Aggiorna la versione del programma
      CreaFileVersione(i);
    }
  }
  if(AutoSpegnimento)
  {
    ImgDownLoad->Visible =false;
    BBtnOK->Visible =false;
    BBtnCancel->Visible =false;
    BtnExit->Visible =false;
    BtnShut->Visible =false;
    Animate1->Visible =false;
    LProgramName->Visible =false;
    Memo1->Visible =false;
    PanelComputerName->Visible =false;
    TimerComputerName->Interval =150;
    Label1->Caption ="Switch OFF";
    Label1->Font->Color =clRed;
    Label1->Visible =true;
  }
  else
  {
    Ethernet =new C_ETHERNET();
    Server->Active =true;
    s32 to =20;
    while(Ethernet->NumPerifericheConnesse ==0 &&-- to)
    {
      SleepEx(500, false);
    }
    ShutDownTesta();
    delete Ethernet;
    // Start application
    SendMessage(Handle, WM_START_APPLICATION, 0, 0);
  }
  // Avviso di aggiornamento terminato
  Animate1->Active =false;
}
